{
    "manifest_version": 3,
    "name": "KD CM Notes",
    "key": "",
    "version": "1.6.9",
    "description": "Omni Purpose Tool for KD Case Manager",
    "author": "Kant Nguyen",
    "permissions": [
        "storage",
        "activeTab",
        "clipboardWrite",
        "unlimitedStorage",
        "downloads",
        "identity"
    ],
    "oauth2": {
        "client_id": "30276438677-joadoueclhd3qh89urs9gqgubljagpir.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/drive.file"
        ]
    },
    "host_permissions": [
        "https://*.lightning.force.com/*",
        "https://*.my.site.com/*",
        "https://raw.githubusercontent.com/*",
        "https://unpkg.com/*",
        "https://nominatim.openstreetmap.org/*",
        "https://*.tile.openstreetmap.org/*",
        "https://ifax.pro/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.lightning.force.com/*",
                "https://*.my.site.com/*"
            ],
            "js": [
                "gm-compat.js",
                "src/config/Themes.js",
                "src/core/Utils.js",
                "src/core/Scraper.js",
                "src/core/SSADataManager.js",
                "src/lib/leaflet.min.js",
                "src/core/DistanceCalculator.js",
                "src/core/PdfManager.js",
                "src/core/WindowManager.js",
                "src/ui/Taskbar.js",
                "src/ui/Dashboard.js",
                "src/ui/panels/ContactForms.js",
                "src/ui/panels/SSDFormViewer.js",
                "src/ui/panels/FeaturePanels.js",
                "src/features/automation/MailResolve.js",
                "src/features/automation/BatchResolve.js",
                "src/features/automation/TaskAutomation.js",
                "src/features/automation/AutomationPanel.js",
                "src/lib/obs-ws.js",
                "src/features/automation/ObsRecorder.js",
                "src/features/client-note/InfoPanel.js",
                "src/features/client-note/SSAPanel.js",
                "src/features/client-note/DDSPanel.js",
                "src/features/client-note/MatterPanel.js",
                "src/features/client-note/NearestOffice.js",
                "src/features/client-note/ClientNote.js",
                "src/ui/panels/MedicationPanel.js",
                "src/core/AppObserver.js",
                "src/ui/Scheduler.js",
                "src/ui/GlobalNotes.js",
                "src/ui/BackupManager.js",
                "src/core/pdf-lib.min.js",
                "content.js"
            ],
            "css": [
                "src/config/Styles.css"
            ],
            "run_at": "document_idle",
            "all_frames": true
        },
        {
            "matches": [
                "https://ifax.pro/sent/create/*"
            ],
            "js": [
                "gm-compat.js",
                "src/features/automation/iFaxAutomation.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/config/Styles.css",
                "src/lib/leaflet.min.js",
                "src/lib/leaflet.min.css",
                "icon/icon48.png"
            ],
            "matches": [
                "https://*.lightning.force.com/*",
                "https://*.my.site.com/*"
            ]
        },
        {
            "resources": [
                "src/features/automation/iFaxinjection.js"
            ],
            "matches": [
                "https://ifax.pro/*"
            ]
        }
    ]
}